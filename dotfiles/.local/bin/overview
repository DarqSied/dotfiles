#!/usr/bin/env bash

# A script to move the whole functionality of a bar(polybar,lemonbar,etc) away
# thus eliminating its need and saving screen real estate using notifications


# Battery Information
battery="/sys/class/power_supply/BAT0"
read -r capacity status < <(awk '/^POWER_SUPPLY_CAPACITY=/ {print $2}' "$battery/uevent" 2>/dev/null) "$battery/status" 2>/dev/null || capacity="N/A" status="N/A"

# CPU Usage
cpu_stats_file="/proc/stat"
cpu_usage() {
    local user nice system idle iowait irq softirq steal guest guest_nice
    read -r user nice system idle iowait irq softirq steal guest guest_nice <<<"$(grep '^cpu ' "$cpu_stats_file")"
    prev_idle=$((idle + iowait))
    prev_total=$((user + nice + system + idle + iowait + irq + softirq + steal))
    sleep 0.5
    read -r user nice system idle iowait irq softirq steal guest guest_nice <<<"$(grep '^cpu ' "$cpu_stats_file")"
    idle=$((idle + iowait))
    total=$((user + nice + system + idle + iowait + irq + softirq + steal))
    echo $((100 * ( (total-prev_total) - (idle-prev_idle) ) / (total-prev_total) ))
}

# Memory Usage
mem_info_file="/proc/meminfo"
mem_usage() {
    local total free used
    read -r total free < <(awk '/MemTotal/ {total=$2} /MemFree/ {free=$2} END {print total, free}' "$mem_info_file")
    echo "${used}KiB / ${total}KiB"
}

# Network Traffic
net_traffic() {
    local IF rx tx con_type con vpn int dur
    if [[ $(nmcli d | grep -w "connected") ]]; then
        IF=$(nmcli d | awk '/connected/ {print $1}')
        rx=$(cat "/sys/class/net/$IF/statistics/rx_bytes")
        tx=$(cat "/sys/class/net/$IF/statistics/tx_bytes")
        sleep 1
        rx=$((($(cat "/sys/class/net/$IF/statistics/rx_bytes") - $rx) / 1024))
        tx=$((($(cat "/sys/class/net/$IF/statistics/tx_bytes") - $tx) / 1024))
        con_type=$(nmcli d | awk '/connected/ {print $2}')
        con=$(nmcli d | awk '/connected/ {print $NF}')
        vpn=$(nmcli d | grep -w tun && echo "[V]" || echo "[-]")
        int="Connected to $con_type : $con $vpn\nNet Traffic      Up: ${tx}KB   Down: ${rx}KB"
        dur="2000"
    else
        int="You are currently offline."
        dur="8000"
    fi
    echo "$int"
}

# Notification
while true; do
    cpu=$(cpu_usage)
    mem=$(mem_usage)
    int=$(net_traffic)
    dunstify -r 9992 -t $dur "System Overview" "Battery is at $capacity% [$status].
CPU usage is $cpu%.
Memory is at $mem.
$int"
    sleep 1
done
